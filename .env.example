# ==============================================================
# TransitOps — Workspace Configuration Template
# ==============================================================

# ── Backend Configurations (transitops-backend) ──────────────
PORT=5000
DATABASE_URL="postgresql://postgres:password@localhost:5432/transitops"
JWT_SECRET="replace-this-with-a-secure-random-key"
JWT_EXPIRES_IN="30d"

# ── Frontend Configurations (transitops-frontend) ─────────────
# In dev/production, the frontend connects to http://localhost:5000/api
NEXT_PUBLIC_API_URL="http://localhost:5000/api"
